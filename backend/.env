# sbt project — chemin absolu vers le dossier contenant build.sbt
SBT_PROJECT_DIR=/home/nisseya/esgi/4a/spark/projet-spark/spark-scala

# Durée de vie des URLs présignées (secondes) — 15 min
PRESIGN_TTL=900